# Optional. When username/password are set, API endpoints require a login session.
# Use the same values as apps/webapp/.env.local.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me
AUTH_SECRET=change-this-long-random-session-secret

# Required. Used to encrypt database passwords and storage credentials at rest.
# Generate one with: openssl rand -hex 32
ENCRYPTION_KEY=change-this-to-a-64-char-hex-string
