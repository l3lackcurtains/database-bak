{
  "name": "database-bak",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write '**/*.{ts,tsx,md}'",
    "kill-ports": "fuser -k 7301/tcp 7300/tcp 2>/dev/null; true",
    "reset": "fuser -k 7301/tcp 7300/tcp 2>/dev/null; true && turbo dev"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "latest"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "better-sqlite3": "^12.10.0"
  }
}
